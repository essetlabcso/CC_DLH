# DEC Learning Hub environment template
# Copy to .env.local for local development. Do not commit secrets.

# -----------------------------------------------------------------------------
# Public app metadata
# -----------------------------------------------------------------------------

NEXT_PUBLIC_APP_NAME="DEC Learning Hub"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# -----------------------------------------------------------------------------
# Auth and session foundation
# -----------------------------------------------------------------------------

# Required in staging/production. Local development falls back to an internal
# dev-only value if this is empty, but real environments must set a strong secret.
AUTH_SECRET="replace-with-a-strong-random-secret"

# Signed session cookie name used by middleware route boundaries.
DEC_SESSION_COOKIE="dec_session"

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------

# Local development database. Production/staging should provide their own URL.
DATABASE_URL="file:./dev.db"

# -----------------------------------------------------------------------------
# Supabase baseline, planned integration
# -----------------------------------------------------------------------------

# The DEC spec names Supabase as the recommended Phase 1 baseline for auth,
# PostgreSQL/database access, and storage. These values are intentionally listed
# for environment planning, but the current scaffold does not read them yet.
# They become required when Supabase auth/storage/PostgreSQL integration is wired.
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_ANON_KEY=""

# Server-only. Never expose this to client components or NEXT_PUBLIC variables.
SUPABASE_SERVICE_ROLE_KEY=""

# -----------------------------------------------------------------------------
# AI authoring, planned integration
# -----------------------------------------------------------------------------

# Optional until governed AI authoring is implemented.
OPENAI_API_KEY=""
