{
  "name": "dec-learning-hub",
  "version": "0.0.0",
  "private": true,
  "description": "DEC Learning Hub foundation scaffold.",
  "scripts": {
    "dev": "next dev",
    "start": "next start",
    "build": "next build",
    "db:generate": "prisma generate",
    "db:apply:local": "node scripts/apply-local-sqlite.mjs",
    "db:migrate": "prisma migrate dev",
    "db:seed:admin-reference": "node scripts/seed-admin-reference-data.mjs",
    "db:seed:course-creator-demo": "node scripts/seed-course-creator-demo.mjs",
    "db:seed:golden-path": "node scripts/seed-golden-path.mjs",
    "db:setup:local": "npm run db:apply:local && npm run db:generate",
    "db:validate": "prisma validate",
    "lint": "eslint .",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@prisma/client": "6.19.3",
    "next": "15.5.15",
    "react": "19.2.5",
    "react-dom": "19.2.5"
  },
  "devDependencies": {
    "@types/node": "25.6.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "eslint": "9.39.4",
    "eslint-config-next": "15.5.15",
    "prisma": "6.19.3",
    "typescript": "5.9.3",
    "vitest": "4.1.5"
  },
  "engines": {
    "node": ">=24.0.0",
    "npm": ">=11.0.0"
  }
}
